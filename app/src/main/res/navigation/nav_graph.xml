<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/fragmentFiles">
    <fragment
        android:id="@+id/fragmentFiles"
        android:name="com.example.finalexer2grp2.FragmentFiles"
        android:label="fragment_files2"
        tools:layout="@layout/fragment_files" >
        <action
            android:id="@+id/action_fragmentFiles_to_fragmentView"
            app:destination="@id/fragmentView" />
        <action
            android:id="@+id/action_fragmentFiles_to_fragmentEdit"
            app:destination="@id/fragmentEdit" />
    </fragment>
    <fragment
        android:id="@+id/fragmentView"
        android:name="com.example.finalexer2grp2.FragmentView"
        android:label="fragment_view2"
        tools:layout="@layout/fragment_view" >
        <action
            android:id="@+id/action_fragmentView_to_fragmentEdit"
            app:destination="@id/fragmentEdit" />
    </fragment>
    <fragment
        android:id="@+id/fragmentEdit"
        android:name="com.example.finalexer2grp2.FragmentEdit"
        android:label="fragment_fragment_edit"
        tools:layout="@layout/fragment_edit" />
</navigation>